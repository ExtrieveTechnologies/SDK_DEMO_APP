<resources>
    <style name="TopBar.Base" parent="Widget.AppCompat.Toolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/top_bar_height</item>
        <item name="android:background">@color/white</item>
        <item name="android:elevation">@dimen/elevation_standard</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="OptionBarButton">
        <item name="android:layout_width">@dimen/icon_size_medium</item>
        <item name="android:layout_height">@dimen/icon_size_medium</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:padding">@dimen/spacing_medium</item>
    </style>

    <style name="MenuButtonLayout">
        <item name="android:layout_width">0dp</item>
        <item name="android:minHeight">90dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/button_bg</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">@dimen/spacing_small</item>
    </style>

    <style name="MenuButtonIcon">
        <item name="android:layout_width">@dimen/icon_size_xlarge</item>
        <item name="android:layout_height">@dimen/icon_size_xlarge</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:tint">@color/secondary</item>
    </style>

    <style name="MenuButtonLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:layout_marginTop">@dimen/spacing_micro</item>
        <item name="android:textColor">@color/secondary</item>
        <item name="android:textSize">@dimen/font_size_small</item>
        <item name="android:maxLines">2</item>
    </style>
</resources>